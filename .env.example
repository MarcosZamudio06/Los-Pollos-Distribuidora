NODE_ENV=production


FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5433

PORT=4000
API_PREFIX=api
SWAGGER_PATH=docs
CORS_ORIGIN=http://localhost:3000

DATABASE_SSL=false
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=pollo_distribucion
# Keep POSTGRES_* above DATABASE_URL so Docker Compose can interpolate them when this file is copied to .env.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
# Obligatorios. Genera valores aleatorios independientes de al menos 32 caracteres.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

VITE_API_URL=/api
